#!/usr/bin/env python3
"""kb-calendar-sync — ingest Google Calendar attendees into Vepol People.

Usage:
  kb-calendar-sync [--days 30] [--dry-run] [--reauth]
"""

import sys
from pathlib import Path

sys.path.insert(0, str(Path(__file__).parent))

import click
from _kb_people import card, index, dedup
from _kb_people.channel import send


@click.command()
@click.option("--days", default=30, show_default=True, help="Days back to scan")
@click.option("--dry-run", is_flag=True, help="Print what would happen, no writes")
@click.option("--reauth", is_flag=True, help="Force re-authentication with Google")
def main(days, dry_run, reauth):
    """Sync Google Calendar attendees to people/ contacts."""
    try:
        from _kb_people.sources.calendar_source import CalendarSource
    except ImportError as e:
        click.echo(f"Error: {e}", err=True)
        sys.exit(1)

    click.echo(f"Scanning Google Calendar (last {days} days){'  [DRY RUN]' if dry_run else ''}...")

    source = CalendarSource(days_back=days, reauth=reauth)
    try:
        contacts = source.get_contacts()
    except FileNotFoundError as e:
        click.echo(str(e), err=True)
        sys.exit(1)

    if not contacts:
        click.echo("No attendees found.")
        return

    # Deduplicate by email within this batch
    seen_emails: set[str] = set()
    unique_contacts = []
    for c in contacts:
        key = c["email"].lower()
        if key not in seen_emails:
            seen_emails.add(key)
            unique_contacts.append(c)

    updated = 0
    created_draft = 0
    created = 0

    draft_names = []

    for c in unique_contacts:
        result = dedup.resolve(c["name"], email=c["email"])
        action = result["action"]

        if dry_run:
            click.echo(f"  [{action}] {c['name']} <{c['email']}> — {c['context']}")
            continue

        if action == "update":
            uid = result["uid"]
            slug = index.get_slug(uid)
            if slug:
                card.upsert_sighting(slug, c["date"], "calendar", c["context"])
                index.register(uid, slug, c["name"], {"email": c["email"]})
                updated += 1

        else:
            is_draft = action == "create-draft"
            dup_of = result.get("possible_duplicate_of", "")
            path = card.create(
                c["name"],
                email=c["email"],
                source="calendar",
                draft=is_draft,
                possible_duplicate_of=dup_of,
            )
            slug = path.stem
            post = card.load(slug)
            uid = post["id"]
            index.register(uid, slug, c["name"], {"email": c["email"]})
            card.upsert_sighting(slug, c["date"], "calendar", c["context"])

            if is_draft:
                created_draft += 1
                draft_names.append(c["name"])
            else:
                created += 1

    if dry_run:
        return

    click.echo(f"\nDone: {updated} updated, {created} created, {created_draft} drafts.")

    if draft_names:
        names_list = "\n".join(f"  • {n}" for n in draft_names[:10])
        suffix = f"\n  … and {len(draft_names) - 10} more" if len(draft_names) > 10 else ""
        msg = f"📋 New contacts from calendar — review drafts in people/:\n{names_list}{suffix}"
        send("people-drafts", msg)


if __name__ == "__main__":
    main()
