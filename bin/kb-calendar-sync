#!/usr/bin/env python3
"""kb-calendar-sync — ingest Google Calendar attendees into Vepol People.

Calendar data is fetched through the configured MCP host (Claude Code
+ Google Calendar MCP server). See docs/methodology/mcp-first-sources.md
for the principle and docs/modules/people.md for module context.

Usage:
  kb-calendar-sync [--days 30] [--dry-run]

Exit codes:
  0  success
  1  unexpected error
  2  invalid CLI arguments (Click default for usage errors)
  3  MCP host unavailable (claude binary missing, exit non-zero, timeout)
  4  MCP tool error (auth missing, scope denied, calendar not connected)
  5  MCP envelope schema error (host returned malformed response)
"""

import sys
from pathlib import Path

sys.path.insert(0, str(Path(__file__).parent))

import click
from _kb_people import card, index, dedup
from _kb_people.channel import send
from _kb_mcp.runner import McpHostError, McpResponseError, McpToolError


@click.command()
@click.option("--days", default=30, show_default=True, help="Days back to scan")
@click.option("--dry-run", is_flag=True, help="Print what would happen, no writes")
def main(days, dry_run):
    """Sync Google Calendar attendees to people/ contacts via MCP."""
    from _kb_people.sources.calendar_source import CalendarSource

    click.echo(f"Scanning Google Calendar (last {days} days){'  [DRY RUN]' if dry_run else ''}...")

    source = CalendarSource(days_back=days)
    try:
        contacts = source.get_contacts()
    except McpHostError as e:
        click.echo(
            f"MCP host unavailable: {e}\n"
            "→ Run `kb-doctor --mode mcp-check` for a diagnostic.",
            err=True,
        )
        sys.exit(3)
    except McpToolError as e:
        click.echo(
            f"MCP tool error: {e.error}: {e.detail}\n"
            "→ This usually means the Google Calendar MCP server isn't "
            "connected or hasn't been authorized in Claude Code's MCP "
            "settings. Open Claude Code → MCP and verify the connector.",
            err=True,
        )
        sys.exit(4)
    except McpResponseError as e:
        click.echo(
            f"MCP envelope error: {e}\n"
            "→ The host returned a response that didn't match the expected "
            "schema. This is a Vepol or MCP-server bug — please report.",
            err=True,
        )
        sys.exit(5)

    if not contacts:
        click.echo("No attendees found.")
        return

    # Deduplicate by email within this batch
    seen_emails: set[str] = set()
    unique_contacts = []
    for c in contacts:
        key = c["email"].lower()
        if key not in seen_emails:
            seen_emails.add(key)
            unique_contacts.append(c)

    updated = 0
    created_draft = 0
    created = 0

    draft_names = []

    for c in unique_contacts:
        result = dedup.resolve(c["name"], email=c["email"])
        action = result["action"]

        if dry_run:
            click.echo(f"  [{action}] {c['name']} <{c['email']}> — {c['context']}")
            continue

        # Provenance: tag each sighting with a short request_id slice so an
        # audit can grep all rows from one fetch. Per
        # docs/methodology/mcp-first-sources.md § Security: provenance.
        rid = (c.get("request_id") or "")[:8]
        sighting_source = f"calendar/{rid}" if rid else "calendar"

        if action == "update":
            uid = result["uid"]
            slug = index.get_slug(uid)
            if slug:
                card.upsert_sighting(slug, c["date"], sighting_source, c["context"])
                index.register(uid, slug, c["name"], {"email": c["email"]})
                updated += 1

        else:
            is_draft = action == "create-draft"
            dup_of = result.get("possible_duplicate_of", "")
            path = card.create(
                c["name"],
                email=c["email"],
                source="calendar",
                draft=is_draft,
                possible_duplicate_of=dup_of,
            )
            slug = path.stem
            post = card.load(slug)
            uid = post["id"]
            index.register(uid, slug, c["name"], {"email": c["email"]})
            card.upsert_sighting(slug, c["date"], sighting_source, c["context"])

            if is_draft:
                created_draft += 1
                draft_names.append(c["name"])
            else:
                created += 1

    if dry_run:
        return

    click.echo(f"\nDone: {updated} updated, {created} created, {created_draft} drafts.")

    if draft_names:
        names_list = "\n".join(f"  • {n}" for n in draft_names[:10])
        suffix = f"\n  … and {len(draft_names) - 10} more" if len(draft_names) > 10 else ""
        msg = f"📋 New contacts from calendar — review drafts in people/:\n{names_list}{suffix}"
        send("people-drafts", msg)


if __name__ == "__main__":
    main()
