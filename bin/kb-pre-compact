#!/usr/bin/env bash
# kb-pre-compact — PreCompact hook wrapper. Captures context before auto-compaction.
# Same env setup as kb-session-end, but delegates to hooks/pre-compact.py.
set -e

STDIN_JSON="$(cat)"
PROJECT="${CLAUDE_PROJECT_DIR:-}"
if [[ -z "$PROJECT" ]]; then
  PROJECT=$(printf '%s' "$STDIN_JSON" | python3 -c 'import sys,json
try:
    print(json.load(sys.stdin).get("cwd",""))
except Exception:
    pass' 2>/dev/null || true)
fi

if [[ -z "$PROJECT" || ! -f "$PROJECT/knowledge/log.md" || -e "$PROJECT/.kb-ignore" ]]; then
  exit 0
fi

case "$PROJECT" in
  "$HOME"|/tmp|/tmp/*|/private/tmp|/private/tmp/*|/usr|/usr/*|/opt|/opt/*|/etc|/etc/*)
    exit 0
    ;;
esac

export CLAUDE_KB_DAILY_DIR="$PROJECT/knowledge/daily"
export CLAUDE_KB_LOG_FILE="$PROJECT/knowledge/log.md"
export CLAUDE_KB_NO_COMPILE=1

UV_BIN="$(command -v uv || true)"
if [[ -z "$UV_BIN" ]]; then
  for candidate in \
    /opt/homebrew/bin/uv \
    /usr/local/bin/uv \
    "$HOME/.local/bin/uv" \
    "$HOME/.cargo/bin/uv" \
    "$HOME/.langflow/uv/uv"; do
    if [[ -x "$candidate" ]]; then
      UV_BIN="$candidate"
      break
    fi
  done
fi
if [[ -z "$UV_BIN" ]]; then
  echo "kb-pre-compact: uv not found in PATH or known locations; skipping flush" >&2
  exit 0
fi

printf '%s' "$STDIN_JSON" | "$UV_BIN" run --directory "$HOME/claude-memory-compiler" python "$HOME/claude-memory-compiler/hooks/pre-compact.py"
