#!/usr/bin/env python3
"""Runs every 15 minutes via launchd. Reads today-plan.json and fires kb-brief /
kb-retro when their scheduled time arrives. Marks `brief_fired` / `retro_fired`
so it only fires once per day. Self-heals: if plan is missing or stale (not for
today), regenerates it by invoking kb-planner.
"""
import datetime
import json
import os
import pathlib
import subprocess

HUB = pathlib.Path(os.environ.get("KB_HUB", os.path.expanduser("~/knowledge")))
PLAN = HUB / "logs" / "today-plan.json"
LOG = HUB / "logs" / "planner.log"


def log(msg: str) -> None:
    stamp = datetime.datetime.now().isoformat(timespec="seconds")
    with LOG.open("a") as f:
        f.write(f"[{stamp}] tick: {msg}\n")


def load_plan() -> dict | None:
    if not PLAN.exists():
        return None
    try:
        return json.loads(PLAN.read_text())
    except Exception as e:
        log(f"plan parse error: {e}")
        return None


def save_plan(plan: dict) -> None:
    PLAN.write_text(json.dumps(plan, indent=2))


def regenerate_plan() -> dict | None:
    log("regenerating plan via kb-planner")
    subprocess.run([str(HUB / "bin" / "kb-planner")], check=False)
    return load_plan()


def fire(script: str) -> int:
    """Run a hub event script and return its exit code.

    Blocking call. Caller decides whether to mark `*_fired=true` based on
    rc==0. Was Popen+start_new_session previously, but that path set the
    fired flag *before* the script finished — if kb-retro/kb-brief crashed
    the flag was already true and the message never went out, with no retry
    on the next tick. Incident-2026-05-05.

    Launchd's StartInterval=900 schedule re-fires only after the previous
    instance exits, so blocking here for ~3 min (retro) or ~6 min (brief)
    only shifts the next tick, it doesn't stack instances.
    """
    log(f"firing {script}")
    proc = subprocess.run(
        [str(HUB / "bin" / script)],
        stdout=subprocess.DEVNULL,
        stderr=subprocess.DEVNULL,
    )
    log(f"{script} completed rc={proc.returncode}")
    return proc.returncode


def channel_instances_guard() -> None:
    """Incident-2026-04-25: every tick (15 min), check telegram channel
    plugin instance count. If duplicates accumulated, run cleanup. If
    channel is down, append escalation. Wrapped in try/except so a flap
    here doesn't break brief/retro firing."""
    try:
        proc = subprocess.run(
            [str(HUB / "bin" / "kb-doctor"), "channel-instances", "--format", "json"],
            capture_output=True, text=True, timeout=15,
        )
        data = json.loads(proc.stdout) if proc.stdout.strip() else {}
        findings = data.get("findings", [])
        for f in findings:
            kind = f.get("kind", "")
            sev = f.get("severity", "")
            if kind == "channel-instances:duplicate" and sev == "P1":
                log(f"channel-instances:duplicate detected — running cleanup")
                subprocess.run(
                    [str(HUB / "bin" / "kb-codex-cleanup")],
                    capture_output=True, timeout=30,
                )
            elif kind == "channel-instances:down" and sev == "P0":
                log(f"channel-instances:down detected — re-bootstrapping LaunchAgent")
                plist = pathlib.Path.home() / "Library" / "LaunchAgents" / "com.knowledge.channel-telegram.plist"
                if plist.is_file():
                    subprocess.run(
                        ["launchctl", "bootstrap", f"gui/{os.getuid()}", str(plist)],
                        capture_output=True, timeout=10,
                    )
    except Exception as exc:
        log(f"channel-instances guard error (non-fatal): {exc!r}")


def main() -> None:
    today = datetime.date.today().isoformat()
    now_hm = datetime.datetime.now().strftime("%H:%M")

    # Incident-2026-04-25: telegram channel instance guard runs every tick.
    channel_instances_guard()

    plan = load_plan()
    if plan is None or plan.get("date") != today:
        plan = regenerate_plan()
        if plan is None:
            log("plan still missing after regen, abort")
            return

    # Brief — only mark fired on rc==0 so a crash retries on next tick
    # rather than silently swallowing the day's brief.
    if not plan.get("brief_fired") and now_hm >= plan["brief_hm"]:
        rc = fire("kb-brief")
        if rc == 0:
            plan["brief_fired"] = True
            save_plan(plan)
        else:
            log(f"brief rc={rc}, brief_fired NOT set; will retry next tick")

    # Retro — same retry-on-failure semantics. Note: on most days
    # kb-orchestrator-cycle (20:45 cron) marks retro_fired=true before this
    # tick checks, so this branch is the fallback path when cycle is
    # disabled or fails.
    if not plan.get("retro_fired") and now_hm >= plan["retro_hm"]:
        rc = fire("kb-retro")
        if rc == 0:
            plan["retro_fired"] = True
            save_plan(plan)
        else:
            log(f"retro rc={rc}, retro_fired NOT set; will retry next tick")


if __name__ == "__main__":
    main()
